#!/usr/bin/env bash
# Command Center CLI — tools for Captain, agents, and project management
set -e
DIR="$(cd "$(dirname "$0")/.." && pwd)"
CC_PORT="${CC_PORT:-3300}"
BASE_URL="http://localhost:${CC_PORT}"
PROJECT="${CC_PROJECT:-companion}"
AGENT="${CC_AGENT:-captain}"

json_post() {
  curl -s -X POST "$BASE_URL$1" -H 'Content-Type: application/json' -H "X-Project-Id: $PROJECT" -H "X-Agent-Id: $AGENT" -d "$2"
}
json_get() {
  curl -s "$BASE_URL$1" -H "X-Project-Id: $PROJECT" -H "X-Agent-Id: $AGENT"
}
json_patch() {
  curl -s -X PATCH "$BASE_URL$1" -H 'Content-Type: application/json' -H "X-Project-Id: $PROJECT" -H "X-Agent-Id: $AGENT" -d "$2"
}
json_delete() {
  curl -s -X DELETE "$BASE_URL$1" -H "X-Project-Id: $PROJECT" -H "X-Agent-Id: $AGENT"
}
urlencode() {
  python3 -c "import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=''))" "$1"
}

case "${1:-help}" in

  # ── Task commands ─────────────────────────────────────────────
  task)
    case "${2:-list}" in
      create)
        shift 2
        TITLE="" PRIORITY="normal" LABELS="" ISSUE="" ASSIGNEE="" DESC="" COLLABORATORS=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --title) TITLE="$2"; shift 2;;
            --priority) PRIORITY="$2"; shift 2;;
            --labels) LABELS="$2"; shift 2;;
            --github-issue) ISSUE="$2"; shift 2;;
            --assignee) ASSIGNEE="$2"; shift 2;;
            --description) DESC="$2"; shift 2;;
            --collaborators) COLLABORATORS="$2"; shift 2;;
            *) echo "Unknown flag: $1"; exit 2;;
          esac
        done
        [ -z "$TITLE" ] && echo "Error: --title is required" && exit 2
        BODY="{\"title\":\"$TITLE\",\"priority\":\"$PRIORITY\",\"createdBy\":\"captain\""
        [ -n "$DESC" ] && BODY="$BODY,\"description\":\"$DESC\""
        [ -n "$ISSUE" ] && BODY="$BODY,\"githubIssue\":$ISSUE"
        [ -n "$ASSIGNEE" ] && BODY="$BODY,\"assignee\":\"$ASSIGNEE\""
        [ -n "$COLLABORATORS" ] && BODY="$BODY,\"collaborators\":[$(echo "$COLLABORATORS" | tr ',' '\n' | jq -Rn '[inputs]' | sed 's/^\[//;s/\]$//')]"
        [ -n "$LABELS" ] && BODY="$BODY,\"labels\":[$(echo "$LABELS" | sed 's/[^,]*/\"&\"/g')]"
        BODY="$BODY}"
        json_post "/api/tasks" "$BODY"
        ;;
      list)
        shift 2 2>/dev/null || true
        QUERY=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --state) QUERY="${QUERY}&state=$2"; shift 2;;
            --assignee) QUERY="${QUERY}&assignee=$2"; shift 2;;
            --priority) QUERY="${QUERY}&priority=$2"; shift 2;;
            --search) QUERY="${QUERY}&search=$(urlencode "$2")"; shift 2;;
            --labels) QUERY="${QUERY}&labels=$(urlencode "$2")"; shift 2;;
            *) shift;;
          esac
        done
        json_get "/api/tasks?${QUERY#&}"
        ;;
      update)
        shift 2
        ID="" STATE="" NOTE="" ASSIGNEE="" PR="" DESIGN_DOCS=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --id) ID="$2"; shift 2;;
            --state) STATE="$2"; shift 2;;
            --note) NOTE="$2"; shift 2;;
            --assignee) ASSIGNEE="$2"; shift 2;;
            --pr) PR="$2"; shift 2;;
            --design-docs) DESIGN_DOCS="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$ID" ] && echo "Error: --id is required" && exit 2
        BODY="{\"actor\":\"$AGENT\""
        [ -n "$STATE" ] && BODY="$BODY,\"state\":\"$STATE\""
        [ -n "$NOTE" ] && BODY="$BODY,\"latestUpdate\":\"$NOTE\""
        [ -n "$ASSIGNEE" ] && BODY="$BODY,\"assignee\":\"$ASSIGNEE\""
        [ -n "$PR" ] && BODY="$BODY,\"githubPR\":$PR"
        if [ -n "$DESIGN_DOCS" ]; then
          # Convert comma-separated list to JSON array
          JSON_ARR="["; FIRST=true
          IFS=',' read -ra DOCS <<< "$DESIGN_DOCS"
          for doc in "${DOCS[@]}"; do
            doc="$(echo "$doc" | xargs)"
            [ "$FIRST" = true ] && FIRST=false || JSON_ARR="$JSON_ARR,"
            JSON_ARR="$JSON_ARR\"$doc\""
          done
          JSON_ARR="$JSON_ARR]"
          BODY="$BODY,\"designDocs\":$JSON_ARR"
        fi
        BODY="$BODY}"
        json_patch "/api/tasks/$ID" "$BODY"
        ;;
      complete)
        shift 2
        ID="" NOTE=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --id) ID="$2"; shift 2;;
            --note) NOTE="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$ID" ] && echo "Error: --id is required" && exit 2
        BODY="{\"actor\":\"$AGENT\""
        [ -n "$NOTE" ] && BODY="$BODY,\"notes\":\"$NOTE\""
        BODY="$BODY}"
        json_post "/api/tasks/$ID/complete" "$BODY"
        ;;
      get)
        shift 2
        ID=""
        while [[ $# -gt 0 ]]; do case "$1" in --id) ID="$2"; shift 2;; *) shift;; esac done
        [ -z "$ID" ] && echo "Error: --id is required" && exit 2
        json_get "/api/tasks/$ID"
        ;;
      subscribe)
        shift 2
        ID=""
        while [[ $# -gt 0 ]]; do case "$1" in --id) ID="$2"; shift 2;; *) shift;; esac done
        [ -z "$ID" ] && echo "Error: --id is required" && exit 2
        json_post "/api/tasks/$ID/subscribe" "{}"
        ;;
      sync)
        json_post "/api/tasks/sync-from-github" "{}"
        ;;
      *) echo "Usage: cc task <create|list|get|update|complete|subscribe|sync>"; exit 2;;
    esac
    ;;

  # ── Agent commands ────────────────────────────────────────────
  agent)
    case "${2:-list}" in
      create)
        shift 2
        NAME="" ROLE="" ID=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --name) NAME="$2"; shift 2;;
            --role) ROLE="$2"; shift 2;;
            --id) ID="$2"; shift 2;;
            *) echo "Unknown flag: $1"; exit 2;;
          esac
        done
        [ -z "$NAME" ] && echo "Error: --name is required" && exit 2
        BODY="{\"name\":\"$NAME\""
        [ -n "$ROLE" ] && BODY="$BODY,\"role\":\"$ROLE\""
        [ -n "$ID" ] && BODY="$BODY,\"id\":\"$ID\""
        BODY="$BODY}"
        json_post "/api/agents" "$BODY"
        ;;
      list)
        json_get "/api/agents"
        ;;
      get)
        shift 2
        ID=""
        while [[ $# -gt 0 ]]; do case "$1" in --id) ID="$2"; shift 2;; *) shift;; esac done
        [ -z "$ID" ] && echo "Error: --id is required" && exit 2
        json_get "/api/agents/$ID"
        ;;
      update)
        shift 2
        ID="" STATUS="" ROLE=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --id) ID="$2"; shift 2;;
            --status) STATUS="$2"; shift 2;;
            --role) ROLE="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$ID" ] && echo "Error: --id is required" && exit 2
        BODY="{"
        [ -n "$STATUS" ] && BODY="$BODY\"status\":\"$STATUS\","
        [ -n "$ROLE" ] && BODY="$BODY\"role\":\"$ROLE\","
        BODY="${BODY%,}}"
        json_patch "/api/agents/$ID" "$BODY"
        ;;
      delete)
        shift 2
        ID=""
        while [[ $# -gt 0 ]]; do case "$1" in --id) ID="$2"; shift 2;; *) shift;; esac done
        [ -z "$ID" ] && echo "Error: --id is required" && exit 2
        json_delete "/api/agents/$ID"
        ;;
      *) echo "Usage: cc agent <create|list|get|update|delete>"; exit 2;;
    esac
    ;;

  # ── Thread commands ──────────────────────────────────────────
  thread)
    case "${2:-list}" in
      list)
        shift 2 2>/dev/null || true
        LIMIT="${1:-20}"
        json_get "/api/threads?limit=$LIMIT"
        ;;
      create)
        shift 2
        NAME="" PARTICIPANTS=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --name) NAME="$2"; shift 2;;
            --participants) PARTICIPANTS="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$NAME" ] && echo "Error: --name is required" && exit 2
        if [ -n "$PARTICIPANTS" ]; then
          PARTS_JSON=$(echo "$PARTICIPANTS" | tr ',' '\n' | jq -Rn '[inputs | {participantType: "assistant", participantId: .}]')
          BODY=$(jq -nc --arg t "$NAME" --argjson p "$PARTS_JSON" '{title: $t, participants: $p}')
        else
          BODY=$(jq -nc --arg t "$NAME" '{title: $t}')
        fi
        json_post "/api/threads" "$BODY"
        ;;
      *) echo "Usage: cc thread <list|create>"; exit 2;;
    esac
    ;;

  # ── Message commands ─────────────────────────────────────────
  msg)
    case "${2:-}" in
      send)
        shift 2
        THREAD="" TEXT="" IMAGE=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --thread) THREAD="$2"; shift 2;;
            --text) TEXT="$2"; shift 2;;
            --image) IMAGE="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$THREAD" ] && echo "Error: --thread is required" && exit 2
        if [ -n "$IMAGE" ]; then
          [ ! -f "$IMAGE" ] && echo "Error: image file not found: $IMAGE" && exit 2
          CURL_ARGS=(-s -X POST "$BASE_URL/api/message/image?threadId=$THREAD"
            -H "X-Project-Id: $PROJECT" -H "X-Agent-Id: $AGENT"
            -F "image=@$IMAGE"
            -F "sender=$AGENT"
            -F "source=cli")
          [ -n "$TEXT" ] && CURL_ARGS+=(-F "caption=$TEXT")
          curl "${CURL_ARGS[@]}"
        else
          [ -z "$TEXT" ] && echo "Error: --text is required (or use --image)" && exit 2
          json_post "/api/message" "{\"thread_id\":\"$THREAD\",\"text\":\"$TEXT\",\"sender\":\"$AGENT\",\"source\":\"cli\"}"
        fi
        ;;
      history)
        shift 2
        THREAD="" LIMIT="20"
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --thread) THREAD="$2"; shift 2;;
            --limit) LIMIT="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$THREAD" ] && echo "Error: --thread is required" && exit 2
        json_get "/api/threads/$THREAD/messages?limit=$LIMIT"
        ;;
      *) echo "Usage: cc msg <send|history>"; exit 2;;
    esac
    ;;

  # ── KB commands ───────────────────────────────────────────────
  kb)
    case "${2:-list}" in
      list)
        json_get "/api/kb/list"
        ;;
      read)
        shift 2
        FILE="" SECTION=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --file) FILE="$2"; shift 2;;
            --section) SECTION="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$FILE" ] && echo "Error: --file is required" && exit 2
        QUERY="file=$FILE"
        [ -n "$SECTION" ] && QUERY="$QUERY&section=$SECTION"
        json_get "/api/kb/read?$QUERY"
        ;;
      write)
        shift 2
        FILE="" CONTENT=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --file) FILE="$2"; shift 2;;
            --content) CONTENT="$2"; shift 2;;
            --content-file) CONTENT="$(cat "$2")"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$FILE" ] && echo "Error: --file is required" && exit 2
        [ -z "$CONTENT" ] && echo "Error: --content or --content-file is required" && exit 2
        BODY=$(jq -nc --arg f "$FILE" --arg c "$CONTENT" '{file:$f, content:$c}')
        json_post "/api/kb/write" "$BODY"
        ;;
      append)
        shift 2
        FILE="" TEXT=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --file) FILE="$2"; shift 2;;
            --text) TEXT="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$FILE" ] && echo "Error: --file is required" && exit 2
        [ -z "$TEXT" ] && echo "Error: --text is required" && exit 2
        BODY=$(jq -nc --arg f "$FILE" --arg t "$TEXT" '{file:$f, text:$t}')
        json_post "/api/kb/append" "$BODY"
        ;;
      search)
        shift 2
        QUERY="" FILE=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --query|-q) QUERY="$2"; shift 2;;
            --file) FILE="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$QUERY" ] && echo "Error: --query is required" && exit 2
        PARAMS="q=$QUERY"
        [ -n "$FILE" ] && PARAMS="$PARAMS&file=$FILE"
        json_get "/api/kb/search?$PARAMS"
        ;;
      sections)
        shift 2
        FILE=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --file) FILE="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$FILE" ] && echo "Error: --file is required" && exit 2
        json_get "/api/kb/sections?file=$FILE"
        ;;
      patch)
        shift 2
        FILE="" FIND="" REPLACE="" SECTION="" CONTENT="" APPEND="" REPLACE_ALL="false"
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --file) FILE="$2"; shift 2;;
            --find) FIND="$2"; shift 2;;
            --replace) REPLACE="$2"; shift 2;;
            --section) SECTION="$2"; shift 2;;
            --content) CONTENT="$2"; shift 2;;
            --append) APPEND="$2"; shift 2;;
            --replace-all) REPLACE_ALL="true"; shift;;
            *) shift;;
          esac
        done
        [ -z "$FILE" ] && echo "Error: --file is required" && exit 2
        if [ -n "$FIND" ]; then
          BODY=$(jq -nc --arg f "$FILE" --arg fi "$FIND" --arg r "$REPLACE" --argjson ra "$REPLACE_ALL" \
            '{file:$f, find:$fi, replace:$r, replace_all:$ra}')
        elif [ -n "$APPEND" ]; then
          if [ -n "$SECTION" ]; then
            BODY=$(jq -nc --arg f "$FILE" --arg a "$APPEND" --arg s "$SECTION" '{file:$f, append:$a, section:$s}')
          else
            BODY=$(jq -nc --arg f "$FILE" --arg a "$APPEND" '{file:$f, append:$a}')
          fi
        elif [ -n "$SECTION" ] && [ -n "$CONTENT" ]; then
          BODY=$(jq -nc --arg f "$FILE" --arg s "$SECTION" --arg c "$CONTENT" '{file:$f, section:$s, content:$c}')
        else
          echo "Error: provide --find/--replace, --append, or --section/--content"; exit 2
        fi
        json_post "/api/kb/patch" "$BODY"
        ;;
      delete)
        shift 2
        FILE=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --file) FILE="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$FILE" ] && echo "Error: --file is required" && exit 2
        BODY=$(jq -nc --arg f "$FILE" '{file:$f}')
        json_post "/api/kb/delete" "$BODY"
        ;;
      delete-section)
        shift 2
        FILE="" SECTION=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --file) FILE="$2"; shift 2;;
            --section) SECTION="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$FILE" ] && echo "Error: --file is required" && exit 2
        [ -z "$SECTION" ] && echo "Error: --section is required" && exit 2
        BODY=$(jq -nc --arg f "$FILE" --arg s "$SECTION" '{file:$f, section:$s}')
        json_post "/api/kb/delete-section" "$BODY"
        ;;
      *) echo "Usage: cc kb <list|read|write|append|search|sections|patch|delete|delete-section>"; exit 2;;
    esac
    ;;

  # ── Design commands ────────────────────────────────────────────
  design)
    case "${2:-list}" in
      list)
        shift 2 2>/dev/null || true
        json_get "/api/designs/list"
        ;;
      read)
        shift 2
        FILE=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --file) FILE="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$FILE" ] && echo "Error: --file is required" && exit 2
        json_get "/api/designs/read?file=$(urlencode "$FILE")"
        ;;
      write)
        shift 2
        FILE="" CONTENT=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --file) FILE="$2"; shift 2;;
            --content) CONTENT="$2"; shift 2;;
            --content-file) CONTENT="$(cat "$2")"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$FILE" ] && echo "Error: --file is required" && exit 2
        [ -z "$CONTENT" ] && echo "Error: --content or --content-file is required" && exit 2
        BODY=$(jq -nc --arg f "$FILE" --arg c "$CONTENT" '{file:$f, content:$c}')
        json_post "/api/designs/write" "$BODY"
        ;;
      delete)
        shift 2
        FILE=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --file) FILE="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$FILE" ] && echo "Error: --file is required" && exit 2
        BODY=$(jq -nc --arg f "$FILE" '{file:$f}')
        json_post "/api/designs/delete" "$BODY"
        ;;
      *) echo "Usage: cc design <list|read|write|delete>"; exit 2;;
    esac
    ;;

  # ── Dashboard commands ─────────────────────────────────────────
  dashboard)
    case "${2:-get}" in
      get)
        json_get "/api/dashboard"
        ;;
      set)
        shift 2
        BLOCKS=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --blocks) BLOCKS="$2"; shift 2;;
            *) echo "Unknown flag: $1"; exit 2;;
          esac
        done
        [ -z "$BLOCKS" ] && echo "Error: --blocks is required" && exit 2
        BODY=$(jq -nc --argjson b "$BLOCKS" '{blocks: $b}')
        json_post "/api/dashboard" "$BODY"
        ;;
      *) echo "Usage: cc dashboard <get|set --blocks JSON>"; exit 2;;
    esac
    ;;

  # ── Harness exec ──────────────────────────────────────────────
  exec)
    shift
    CMD="" CWD="" TIMEOUT=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --cwd) CWD="$2"; shift 2;;
        --timeout) TIMEOUT="$2"; shift 2;;
        *) CMD="$1"; shift;;
      esac
    done
    [ -z "$CMD" ] && echo "Error: command argument is required" && exit 2
    BODY="{\"command\":\"$CMD\""
    [ -n "$CWD" ] && BODY="$BODY,\"cwd\":\"$CWD\""
    [ -n "$TIMEOUT" ] && BODY="$BODY,\"timeout\":$TIMEOUT"
    BODY="$BODY}"
    json_post "/api/harness/exec" "$BODY"
    ;;

  # ── iOS Build ─────────────────────────────────────────────────
  ios-build)
    shift
    BUILD_ARGS=""
    THREAD=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --host)     BUILD_ARGS="$BUILD_ARGS --host $2"; shift 2;;
        --repo-dir) BUILD_ARGS="$BUILD_ARGS --repo-dir $2"; shift 2;;
        --no-pull)  BUILD_ARGS="$BUILD_ARGS --no-pull"; shift;;
        --verbose)  BUILD_ARGS="$BUILD_ARGS --verbose"; shift;;
        --thread)   THREAD="$2"; shift 2;;
        *) echo "Unknown flag: $1"; exit 2;;
      esac
    done

    echo "[cc] Starting iOS build via SSH..."
    BUILD_OUTPUT=$("$DIR/bin/ios-build.sh" $BUILD_ARGS 2>&1) && BUILD_EXIT=0 || BUILD_EXIT=$?

    echo "$BUILD_OUTPUT"

    # Post results to thread if requested
    if [ -n "$THREAD" ]; then
      if [ $BUILD_EXIT -eq 0 ]; then
        SUMMARY="iOS build SUCCEEDED"
      else
        ERRORS=$(echo "$BUILD_OUTPUT" | grep -E "error:" | head -5 | tr '\n' '; ' || true)
        SUMMARY="iOS build FAILED"
        [ -n "$ERRORS" ] && SUMMARY="$SUMMARY — $ERRORS"
      fi
      json_post "/api/message" "{\"thread_id\":\"$THREAD\",\"text\":\"$SUMMARY\",\"sender\":\"$AGENT\",\"source\":\"cli\"}" > /dev/null
      echo "[cc] Build result posted to thread."
    fi

    exit $BUILD_EXIT
    ;;

  # ── iOS Build Daemon ──────────────────────────────────────────
  ios-daemon)
    shift
    SSH_HOST="${IOS_BUILD_HOST:-ntan@192.168.86.28}"
    ACTION="${1:-status}"

    case "$ACTION" in
      deploy)
        echo "[cc] Deploying ios-build-daemon.sh to $SSH_HOST..."
        scp -o ConnectTimeout=10 "$DIR/bin/ios-build-daemon.sh" "$SSH_HOST:~/ios-build-daemon.sh"
        ssh -o ConnectTimeout=10 "$SSH_HOST" "bash -c 'chmod +x ~/ios-build-daemon.sh'"
        echo "[cc] Deployed. Use 'cc ios-daemon start' to start."
        ;;
      start)
        echo "[cc] Starting daemon on $SSH_HOST..."
        ssh -o ConnectTimeout=10 "$SSH_HOST" "bash -c '~/ios-build-daemon.sh start'"
        ;;
      stop)
        ssh -o ConnectTimeout=10 "$SSH_HOST" "bash -c '~/ios-build-daemon.sh stop'"
        ;;
      status)
        ssh -o ConnectTimeout=10 "$SSH_HOST" "bash -c '~/ios-build-daemon.sh status'"
        ;;
      log)
        ssh -o ConnectTimeout=10 "$SSH_HOST" "bash -c 'tail -${2:-30} ~/.ios-build-daemon.log 2>/dev/null || echo No log yet'"
        ;;
      *) echo "Usage: cc ios-daemon {deploy|start|stop|status|log [N]}"; exit 2;;
    esac
    ;;

  # ── Board / Ops / Metrics ─────────────────────────────────────
  board)
    json_get "/api/board" | python3 -c "
import json, sys
d = json.load(sys.stdin)
for c in d.get('columns', []):
    print(f\"{c['label']}: {len(c['issues'])} issues\")
" 2>/dev/null || json_get "/api/board"
    ;;

  ops)
    json_get "/api/ops" | python3 -c "
import json, sys
d = json.load(sys.stdin)
builds = d.get('builds', [])
pulls = d.get('pulls', [])
print(f'CI Runs: {len(builds)}')
for b in builds[:5]:
    print(f\"  {b['name']}: {b.get('status','')} / {b.get('conclusion','')} ({b.get('age','')})\")
print(f'Open PRs: {len(pulls)}')
for p in pulls[:5]:
    print(f\"  #{p['number']} {p['title']} by {p.get('author','')} ({p.get('age','')})\")
" 2>/dev/null || json_get "/api/ops"
    ;;

  metrics)
    json_get "/api/tasks" | python3 -c "
import json, sys
d = json.load(sys.stdin)
tasks = d.get('tasks', [])
by_state = {}
for t in tasks:
    s = t.get('state', 'unknown')
    by_state[s] = by_state.get(s, 0) + 1
print(f'Total tasks: {len(tasks)}')
for s, n in sorted(by_state.items()):
    print(f'  {s}: {n}')
" 2>/dev/null || json_get "/api/tasks"
    ;;

  # ── Project commands ───────────────────────────────────────────
  project)
    case "${2:-list}" in
      list)
        json_get "/api/projects"
        ;;
      create)
        shift 2
        NAME="" DIR="" CAPTAIN="Captain"
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --name) NAME="$2"; shift 2;;
            --directory|--dir) DIR="$2"; shift 2;;
            --captain) CAPTAIN="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$NAME" ] && [ -z "$DIR" ] && echo "Error: --name is required (e.g. --name my-project)" && exit 2
        BODY=$(jq -nc --arg n "$NAME" --arg d "$DIR" --arg c "$CAPTAIN" '{name: $n, directory: (if $d == "" then null else $d end), captainName: $c}')
        json_post "/api/projects" "$BODY"
        ;;
      *) echo "Usage: cc project <list|create>"; exit 2;;
    esac
    ;;

  status)
    # Fetch tasks, agents, and registry in parallel
    TASKS_JSON=$(json_get "/api/tasks" 2>/dev/null)
    AGENTS_JSON=$(json_get "/api/agents" 2>/dev/null)
    REG_JSON=$(json_get "/api/registry" 2>/dev/null)

    python3 -c "
import json, sys

tasks_raw = '''$TASKS_JSON'''
agents_raw = '''$AGENTS_JSON'''
reg_raw = '''$REG_JSON'''

try:
    tasks = json.loads(tasks_raw).get('tasks', [])
except: tasks = []
try:
    agents = json.loads(agents_raw).get('agents', [])
except: agents = []
try:
    projects = json.loads(reg_raw).get('projects', [])
except: projects = []

# Find current project
proj_name = '$PROJECT'
proj_info = next((p for p in projects if p['id'] == proj_name), None)
display_name = proj_info['name'] if proj_info else proj_name

# Tasks by state
by_state = {}
for t in tasks:
    s = t.get('state', 'unknown')
    by_state[s] = by_state.get(s, 0) + 1

state_order = ['in_progress', 'assigned', 'blocked', 'in_review', 'created', 'done', 'cancelled']
state_parts = []
for s in state_order:
    if s in by_state:
        state_parts.append(f'{by_state[s]} {s}')
for s in sorted(by_state):
    if s not in state_order:
        state_parts.append(f'{by_state[s]} {s}')

tasks_summary = ', '.join(state_parts) if state_parts else 'no tasks'

# Agents
active = sum(1 for a in agents if a.get('status') == 'active')
bridge_connected = sum(1 for a in agents if a.get('bridgeStatus') == 'connected')
total_agents = len(agents)
if bridge_connected > 0:
    agents_summary = f'{active} active ({bridge_connected}/{total_agents} bridged)'
else:
    agents_summary = f'{active}/{total_agents} active'

print(f'{display_name} | Tasks: {tasks_summary} | Agents: {agents_summary}')
" 2>/dev/null || echo "[cc] status: could not fetch data (is gateway running?)"
    ;;

  # ── Health commands ───────────────────────────────────────────
  health)
    case "${2:-summary}" in
      cleanup)
        json_post "/api/health/cleanup" "{}"
        ;;
      summary|--json)
        HEALTH_JSON=$(json_get "/api/health" 2>/dev/null)
        # Check for error
        if echo "$HEALTH_JSON" | jq -e '.error' >/dev/null 2>&1; then
          echo "$HEALTH_JSON"
          exit 1
        fi
        # Raw JSON mode
        if [ "${2:-}" = "--json" ]; then
          echo "$HEALTH_JSON" | jq .
          exit 0
        fi
        # Formatted summary
        echo "$HEALTH_JSON" | python3 -c "
import json, sys

d = json.load(sys.stdin)
status = d.get('status', 'unknown').upper()
uptime = d.get('uptime_seconds', 0)
h, rem = divmod(int(uptime), 3600)
m, s = divmod(rem, 60)
uptime_str = f'{h}h {m}m {s}s' if h else f'{m}m {s}s'

mem = d.get('memory', {})
rss = mem.get('rss_mb', '?')
heap = mem.get('heap_used_mb', '?')

print(f'System: {status} | Uptime: {uptime_str} | Memory: {rss}MB RSS / {heap}MB Heap')

# Bridges per project
projects = d.get('projects', {})
for pid, proj in projects.items():
    if len(projects) > 1:
        print(f'[{pid}]')
    bridges = proj.get('bridges', {})
    for aid, b in bridges.items():
        bstatus = b.get('status', 'unknown').upper()
        bup = b.get('uptime_seconds', 0)
        bh, brem = divmod(int(bup), 3600)
        bm, bs = divmod(brem, 60)
        bup_str = f'{bh}h {bm}m' if bh else f'{bm}m {bs}s'
        restarts = b.get('restart_count', 0)
        print(f'  {aid}: {bstatus} ({bup_str}, {restarts} restarts)')

    # Stores
    stores = proj.get('stores', {})
    store_parts = []
    for sname, sinfo in stores.items():
        ok = 'OK' if sinfo.get('ok') else 'FAIL'
        store_parts.append(f'{sname}: {ok}')
    if store_parts:
        print(f'  Stores: {\" | \".join(store_parts)}')

sse = d.get('sse', {})
clients = sse.get('connected_clients', '?')
buf = sse.get('buffer_size', '?')
print(f'  SSE: {clients} clients | Buffer: {buf}')
" 2>/dev/null || echo "$HEALTH_JSON"
        ;;
      *) echo "Usage: cc health [--json | cleanup]"; exit 2;;
    esac
    ;;

  # ── Bridge commands ──────────────────────────────────────────
  bridge)
    case "${2:-list}" in
      list)
        BRIDGES_JSON=$(json_get "/api/health/bridges" 2>/dev/null)
        if echo "$BRIDGES_JSON" | jq -e '.error' >/dev/null 2>&1; then
          echo "$BRIDGES_JSON"
          exit 1
        fi
        echo "$BRIDGES_JSON" | python3 -c "
import json, sys

d = json.load(sys.stdin)
bridges = d.get('bridges', [])
if not bridges:
    print('No bridges found.')
    sys.exit(0)

for b in bridges:
    aid = b.get('agent_id', '?')
    status = b.get('status', 'unknown').upper()
    uptime = b.get('uptime_seconds', 0)
    h, rem = divmod(int(uptime), 3600)
    m, s = divmod(rem, 60)
    up_str = f'{h}h {m}m' if h else f'{m}m {s}s'
    restarts = b.get('restart_count', 0)
    last = b.get('last_activity_at', '')
    reason = b.get('last_restart_reason', '')
    line = f'{aid}: {status} (uptime {up_str}, {restarts} restarts)'
    if reason:
        line += f' [last restart: {reason}]'
    print(line)
" 2>/dev/null || echo "$BRIDGES_JSON"
        ;;
      restart|stop|start)
        ACTION="$2"
        shift 2
        BAGENT=""
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --agent) BAGENT="$2"; shift 2;;
            *) shift;;
          esac
        done
        [ -z "$BAGENT" ] && echo "Error: --agent is required" && exit 2
        BODY="{}"
        [ "$ACTION" = "restart" ] && BODY='{"reason":"manual restart via CLI"}'
        json_post "/api/health/bridges/$BAGENT/$ACTION" "$BODY"
        ;;
      *) echo "Usage: cc bridge <list|restart|stop|start> [--agent <id>]"; exit 2;;
    esac
    ;;

  # ── Gateway lifecycle ─────────────────────────────────────────
  start)
    cd "$DIR"
    # Build if needed
    if [ ! -f dist/index.js ] || [ gateway.ts -nt dist/index.js ] || [ index.ts -nt dist/index.js ]; then
      echo "[cc] Building..."
      npx tsc -p tsconfig.json
    fi
    export CC_ROOT="$DIR"
    exec node dist/index.js
    ;;

  build)
    cd "$DIR"
    echo "[cc] Building TypeScript..."
    npx tsc -p tsconfig.json
    echo "[cc] Build complete."
    ;;

  restart)
    cd "$DIR"
    shift
    WAKE="" WAKE_THREAD="main"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --wake) WAKE="$2"; shift 2;;
        --wake-thread) WAKE_THREAD="$2"; shift 2;;
        *) shift;;
      esac
    done
    # Default wake message if none provided
    [ -z "$WAKE" ] && WAKE="Gateway restarted. Resume your previous work."
    echo "[cc] Building TypeScript..."
    npx tsc -p tsconfig.json || { echo "[cc] Build failed, aborting restart."; exit 1; }
    echo "[cc] Stopping gateway on port $CC_PORT..."
    kill $(lsof -ti :$CC_PORT) 2>/dev/null
    sleep 1
    echo "[cc] Starting gateway..."
    export CC_ROOT="$DIR"
    nohup node dist/index.js > /tmp/cc-gateway.log 2>&1 &
    NEW_PID=$!
    # Wait for gateway to be healthy (up to 15s)
    echo "[cc] Waiting for gateway to come up..."
    for i in $(seq 1 15); do
      if curl -s "http://localhost:${CC_PORT}/api/registry" > /dev/null 2>&1; then
        echo "[cc] Gateway restarted (PID $NEW_PID). Logs: /tmp/cc-gateway.log"
        # Always send wake-up message so the agent resumes
        sleep 1  # brief pause for bridges to reconnect
        echo "[cc] Sending wake-up message to thread '$WAKE_THREAD'..."
        curl -s -X POST "http://localhost:${CC_PORT}/api/message" \
          -H 'Content-Type: application/json' \
          -H "X-Project-Id: $PROJECT" \
          -H "X-Agent-Id: $AGENT" \
          -d "{\"thread_id\":\"$WAKE_THREAD\",\"text\":\"[system restart complete] $WAKE\",\"sender\":\"system\",\"source\":\"restart\"}" > /dev/null
        echo "[cc] Wake-up sent."
        exit 0
      fi
      sleep 1
    done
    echo "[cc] Gateway failed to start within 15s. Check /tmp/cc-gateway.log"
    exit 1
    ;;

  # ── Help ──────────────────────────────────────────────────────
  help|--help|-h)
    echo "Command Center CLI"
    echo ""
    echo "Usage: cc <command> [subcommand] [flags]"
    echo ""
    echo "Task Management:"
    echo "  task create   --title <t> [--priority <p>] [--assignee <a>] [--collaborators <c1,c2>] [--github-issue <n>]"
    echo "  task list     [--state <s>] [--assignee <a>] [--priority <p>] [--search <q>] [--labels <l1,l2>]"
    echo "  task update   --id <id> [--state <s>] [--note <n>] [--assignee <a>] [--pr <n>] [--design-docs <comma-sep>]"
    echo "  task complete --id <id> [--note <n>]"
    echo "  task subscribe --id <id>  Subscribe to task updates"
    echo "  task sync     Sync GitHub issues to tasks"
    echo ""
    echo "Agent Management:"
    echo "  agent create  --name <n> [--role <r>] [--id <id>]"
    echo "  agent list"
    echo "  agent get     --id <id>"
    echo "  agent update  --id <id> [--status <s>] [--role <r>]"
    echo "  agent delete  --id <id>"
    echo ""
    echo "Knowledge Base:"
    echo "  kb list"
    echo "  kb read       --file <f> [--section <s>]"
    echo "  kb write      --file <f> --content <c>"
    echo "  kb append     --file <f> --text <t>"
    echo "  kb search     --query <q> [--file <f>]"
    echo "  kb sections   --file <f>"
    echo "  kb patch      --file <f> --find <old> --replace <new> [--replace-all]"
    echo "  kb patch      --file <f> --section <s> --content <c>"
    echo "  kb patch      --file <f> --append <text> [--section <s>]"
    echo "  kb delete     --file <f>"
    echo "  kb delete-section --file <f> --section <s>"
    echo ""
    echo "Design Artifacts:"
    echo "  design list"
    echo "  design read   --file <f>"
    echo "  design write  --file <f> --content <c>"
    echo "  design write  --file <f> --content-file <path>"
    echo "  design delete --file <f>"
    echo ""
    echo "Dashboard:"
    echo "  dashboard get                   Get current dashboard blocks"
    echo "  dashboard set --blocks <json>   Set dashboard blocks (JSON array)"
    echo ""
    echo "Threads & Messages:"
    echo "  thread list   [limit]"
    echo "  thread create --name <n> [--participants <p1,p2>]"
    echo "  msg send      --thread <id> --text <t> [--image <path>]"
    echo "  msg history   --thread <id> [--limit <n>]"
    echo ""
    echo "Project Management:"
    echo "  project list"
    echo "  project create --name <name> [--directory <path>] [--captain <name>]"
    echo ""
    echo "Harness:"
    echo "  exec <cmd>    Execute a bash command via the harness [--cwd <dir>] [--timeout <s>]"
    echo ""
    echo "Views:"
    echo "  board         Show project board"
    echo "  ops           Show CI builds and open PRs"
    echo "  metrics       Show task metrics"
    echo "  status        Show overall status"
    echo ""
    echo "Health & Monitoring:"
    echo "  health        Show system health summary (bridges, stores, SSE)"
    echo "  health --json Full health data as raw JSON"
    echo "  health cleanup Kill stale/orphaned claude processes"
    echo ""
    echo "Bridge Management:"
    echo "  bridge list                    List all bridges with status"
    echo "  bridge restart --agent <id>    Restart a specific bridge"
    echo "  bridge stop    --agent <id>    Stop a specific bridge"
    echo "  bridge start   --agent <id>    Start a stopped bridge"
    echo ""
    echo "iOS Build:"
    echo "  ios-build     Build iOS app via SSH to Mac"
    echo "                [--host <user@host>] SSH target (default: ntan@192.168.86.28)"
    echo "                [--repo-dir <path>] Repo path on Mac (default: ~/code/command-center)"
    echo "                [--no-pull] Skip git pull"
    echo "                [--verbose] Show full xcodebuild output"
    echo "                [--thread <id>] Post result to a thread"
    echo ""
    echo "Gateway:"
    echo "  start         Start the Command Center gateway"
    echo "  build         Build TypeScript (compile only)"
    echo "  restart       Build + restart the gateway (background)"
    echo "                [--wake <msg>] Custom wake-up message (default: resume prompt)"
    echo "                [--wake-thread <id>] Thread for wake-up (default: main)"
    echo ""
    echo "Environment:"
    echo "  CC_PORT       Gateway port (default: 3300)"
    echo "  CC_PROJECT    Project ID (default: companion)"
    ;;

  *) echo "Unknown command: $1. Run 'cc help' for usage."; exit 2;;
esac
